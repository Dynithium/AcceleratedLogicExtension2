{
  "manifest_version": 3,
  "name": "OmniChat AI - Personal AI Companion",
  "version": "1.0.0",
  "description": "A context-aware AI chat client supporting customizable OpenAI-compatible API endpoints, custom model IDs, and local message storage.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "sidePanel",
    "activeTab",
    "scripting",
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pdf.min.mjs", 
        "pdf.worker.min.mjs",
        "tesseract.esm.min.js",
        "worker.min.js",
        "tesseract-core.wasm.js",
        "tesseract-core.wasm"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_title": "OmniChat AI"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
